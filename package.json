    "deck.gl": "^9.2.11",
    "lucide-react": "^1.8.0",
    "mapbox-gl": "^3.21.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-map-gl": "^8.1.0",
    "shadcn": "^4.2.0",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@biomejs/biome": "^1.9.4",
    "@rolldown/plugin-babel": "^0.2.2",
