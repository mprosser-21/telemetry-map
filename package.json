    "codegen": "openapi-typescript ./spec/adsb.openapi.json -o ./src/types/adsb.ts"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "class-variance-authority": "^0.7.1",
